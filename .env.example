# --- Postgres ---
POSTGRES_USER=tcg
POSTGRES_PASSWORD=change-me-locally
POSTGRES_DB=tcg
DATABASE_URL=postgresql://tcg:change-me-locally@db:5432/tcg

# --- Web ---
NODE_ENV=development
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_TRUST_HOST=true
INFERENCE_URL=http://inference:8001
NEXT_PUBLIC_SITE_NAME=TCG Card Recognizer

# --- Admin seed (creates the owner admin account) ---
ADMIN_EMAIL=admin@tcg.local
ADMIN_PASSWORD=change-me-admin

# --- Games (multi-TCG) ---
# Which trading card games are switched on. Pokémon is the concentration by
# default; add more without code changes, e.g. ENABLED_GAMES=pokemon,magic
ENABLED_GAMES=pokemon

# Pricing currency (we're in Belgium → EUR; Cardmarket for Pokémon, Scryfall eur
# for Magic). USD is used only as a fallback when no local price exists.
PREFERRED_CURRENCY=EUR

# --- Inference / enrichment ---
POKEMON_TCG_API_KEY=
MODEL_DIR=/models

# --- Catalogue sync ---
# The (mostly static) card + set catalogue is mirrored into Postgres so request-
# path reads (card/set pages, enrichment, the correction picker) never hit the
# game APIs. The APIs are used ONLY by the sync jobs: a one-off full sync, then a
# daily price-only refresh (prices are the only thing that changes).
#   Full:   curl -XPOST -H "Authorization: Bearer $CATALOG_SYNC_SECRET" \
#             http://localhost:3000/api/catalog/sync -d '{"mode":"full"}'
#   Prices: same URL with '{"mode":"prices"}' (the daily cron; see scripts/catalog-sync.sh)
# Shared secret the cron presents to /api/catalog/sync (an admin session also works).
CATALOG_SYNC_SECRET=

# --- Recognition embedder ---
# classical = CPU-only hand-crafted descriptor (default; no model download).
# onnx      = learned DINOv2-small via ONNX (onnxruntime on the server; model
#             lazily downloaded to /models). Browser-side DINOv2 (transformers.js)
#             is Node-verified (lib/onnxEmbedding.ts, parity cosine 0.9999) and a
#             documented follow-up pending the Next bundler integration.
EMBEDDER=classical

# --- Learned projection head (sub-project 3) ---
# Path to a trained head (train it with `bash scripts/train-head.sh`, which
# writes it to the shared models volume). When set AND EMBEDDER=onnx, a small
# metric-learning MLP is applied on top of DINOv2 to make the embedding
# invariant to phone-photo conditions. Empty = off. Applied in pure numpy.
EMBED_HEAD=

# --- Geometric re-ranking (sub-project 2) ---
# 0/empty = off. When >0, /predict re-orders the embedding shortlist's top-K by
# ORB+RANSAC homography inliers against each candidate's reference image (needs
# the card-image dataset mounted, which docker-compose does read-only). Cards are
# flat rigid objects, so this lifts recall@1 toward the embedding's recall@K.
RERANK_TOP_K=

# --- OCR text channel (opt-in extra; `docker compose --profile extras`) ---
# An extra recognition channel: OCR a card → vectorize the text → pgvector search
# (the SAME Postgres+pgvector store the core recognizer uses; no separate vector
# DB). Its top matches are folded into the scan's name candidates; when the user
# confirms/corrects one it becomes feedback the trainer folds into the index —
# i.e. this extra teaches the model. Off by default; enable with OCR_ENABLED=1
# AND running the `extras` profile (the `ocr` service).
OCR_ENABLED=
OCR_URL=http://ocr:8002

# --- MLOps (MLflow tracking server) ---
MLFLOW_TRACKING_URI=http://mlflow:5000
# Browser link to the MLflow UI shown in the admin MLOps view.
NEXT_PUBLIC_MLFLOW_URL=http://192.168.3.177:5000

# --- AI collection assistant (provider router: Claude and/or local Ollama) ---
# The assistant routes through a provider abstraction (apps/web/lib/llm).
# LLM_PROVIDER selects the backend: claude | ollama | auto (default).
#   auto = prefer Claude when an API key is present (more capable), else the
#   local Ollama model; if the chosen backend is unreachable it falls back to
#   the other. With no key AND no reachable Ollama, the assistant stays inert
#   and shows a "not configured" message (unchanged default behavior).
LLM_PROVIDER=auto

# Claude (Anthropic) — provide a key to enable the cloud backend.
ANTHROPIC_API_KEY=
ASSISTANT_MODEL=claude-opus-4-8

# Local LLM via Ollama (opt-in service: `docker compose --profile llm up -d ollama`,
# then `docker compose exec ollama ollama pull llama3.2:1b`). A small model is
# chosen by default since this box is RAM-tight.
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:1b

# --- VLM-assisted recognition (sub-project 6; opt-in extra) ---
# When the recognizer is uncertain, a vision-language model looks at the photo,
# reads the card's printed text, and picks the right card from the shortlist —
# fusing classical CV with a VLM for accuracy on hard cases + explainability.
# Off by default; the scan path is byte-identical to today unless enabled.
# Enable with VLM_ASSIST=1 (also accepts true/yes/on) AND a usable vision backend.
VLM_ASSIST=
# Which vision backend: claude | ollama | auto (default). `auto` prefers Claude
# when ANTHROPIC_API_KEY is set, else the local Ollama vision model, with
# graceful fallback to the other.
VLM_PROVIDER=auto
# Claude vision model (falls back to ASSISTANT_MODEL, then claude-opus-4-8).
VLM_MODEL=claude-opus-4-8
# Local vision model via Ollama (opt-in: `docker compose --profile llm up -d ollama`,
# then `docker compose exec ollama ollama pull llava:7b`). RAM-heavier than text.
OLLAMA_VISION_MODEL=llava:7b

# --- Sentinel (inert until provided at Phase 4) ---
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SENTINEL_REPO=kobozo/tcg-recognizer
SENTINEL_PAUSED=true

# --- LAN binding (owner works remotely) ---
PUBLIC_HOST=192.168.3.177
