generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

/// Local mirror of the (static) card catalogue, synced from the game APIs. Read
/// paths (enrich, card/set pages) serve from here; the API is hit only by the
/// sync jobs. Prices are refreshed separately (daily) — see priceUpdatedAt.
model CatalogCard {
  id          String  @id // provider card id, e.g. "dp3-3"
  game        String
  name        String
  setId       String
  setName     String
  series      String?
  number      String
  rarity      String?
  supertype   String?
  types       String[]
  hp          String?
  artist      String?
  flavorText  String?
  text        String[] // attacks (Pokémon) / oracle lines (Magic)
  imageSmall  String?
  imageLarge  String?
  releaseDate String? // YYYY-MM-DD or ""
  // Market data — the only fields that change; refreshed daily.
  priceEur        Float?
  priceUsd        Float?
  // Per-finish price breakdown ([{name, price, currency}]) for the card detail
  // page; price-derived, so refreshed together with priceEur/priceUsd.
  variants        Json?
  priceUpdatedAt  DateTime?
  syncedAt    DateTime @default(now()) @updatedAt

  @@index([game, name])
  @@index([game, setId])
  @@index([game, setId, number])
}

/// Local mirror of the (static) set catalogue, synced from the game APIs.
model CatalogSet {
  id          String  @id // provider set id, e.g. "dp3"
  game        String
  name        String
  series      String?
  total       Int     @default(0)
  releaseDate String?
  logo        String?
  symbol      String?
  syncedAt    DateTime @default(now()) @updatedAt

  @@index([game])
  @@index([game, releaseDate])
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  role         Role      @default(USER)
  createdAt    DateTime  @default(now())
  scans        Scan[]
  sessions     Session[]
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Scan {
  id           String    @id @default(cuid())
  userId       String
  game         String    @default("pokemon")
  imagePath    String
  predictions  Json
  modelVersion String
  createdAt    DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  feedback     Feedback?

  @@index([userId, createdAt])
}

/// Human-in-the-loop label: the user confirms or corrects a scan's recognition.
/// These become the active-learning signal the trainer feeds back into the index.
model Feedback {
  id            String   @id @default(cuid())
  scanId        String   @unique
  userId        String
  game          String
  predictedName String
  correctedName String
  // A card belongs to a collection (set) and has a number; capturing these makes
  // a correction precise (name alone is ambiguous across sets/printings).
  correctedSet    String?
  correctedNumber String?
  correctedCardId String?
  correct       Boolean  @default(false)
  createdAt     DateTime @default(now())
  scan          Scan     @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ModelVersion {
  id          String   @id @default(cuid())
  version     String   @unique
  metrics     Json
  datasetSize Int      @default(0)
  isCurrent   Boolean  @default(false)
  trainedAt   DateTime @default(now())
}
