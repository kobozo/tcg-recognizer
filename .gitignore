# Secrets / env
.env
.env.local
*.local

# Node
node_modules/
.next/
next-env.d.ts
dist/
build/
*.tsbuildinfo
npm-debug.log*

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/

# ML artifacts & data (versioned via the models volume / dataset manifests, not git)
ml/models/*
!ml/models/.gitkeep
# Dataset: the *data* is DVC-tracked (local remote), NOT git. The small DVC
# pointer file ml/datasets/pokemon.dvc IS committed so the version is recorded.
# `dvc add` also writes its own ml/datasets/.gitignore entry for /pokemon; the
# rules here are kept consistent with that (data ignored, pointer + metric kept).
ml/datasets/*
!ml/datasets/.gitkeep
!ml/datasets/pokemon.dvc
!ml/datasets/.gitignore
# DVC metric (sub-project 4): small JSON, committed so the model's eval is in git.
!ml/metrics.json

# DVC local-filesystem remote (sub-project 4): the actual data blobs live here;
# never committed to git (that would defeat the purpose of DVC).
/.dvc-remote/
# DVC internals: keep .dvc/config (committed) but ignore the local cache + tmp.
/.dvc/cache
/.dvc/tmp
/.dvc/config.local

# Sentinel local state
services/sentinel/*.sqlite
services/sentinel/data/

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/

# Docker
*.pid

# transformers.js / onnx model cache from parity scripts
.onnx-models-cache/

# retrain logs
logs/
